{
  "expo": {
    "name": "Sparkbox",
    "slug": "sparkbox-mobile",
    "version": "1.1.0",
    "runtimeVersion": "1.1.0",
    "updates": {
      "url": "https://u.expo.dev/aeabd579-045e-45bd-9ccd-fd00cdfc1369"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "sparkbox",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "site.morgen.sparkbox.mobile"
    },
    "android": {
      "package": "site.morgen.sparkbox.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.NEARBY_WIFI_DEVICES",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Sparkbox uses your camera to scan the QR code printed on the device label."
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "cloudApiBase": "https://morgen52.site/familyserver",
      "eas": {
        "projectId": "aeabd579-045e-45bd-9ccd-fd00cdfc1369"
      }
    },
    "owner": "morgen52"
  }
}
